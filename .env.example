# =============================================================================
# the CREASE Batting Lab — Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# Optional variables show their default value.
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────
PORT=5005
SECRET_KEY=generate-a-random-secret-key-here
SITE_DOMAIN=http://localhost:5005
DEBUG=0
DEBUG_AUTH=0                        # Set to 1 to bypass login in dev
SESSION_COOKIE_SECURE=false         # Set to true in production (HTTPS)

# ── Supabase (Authentication + Database) ─────────────────────────── [REQUIRED]
# Get these from: Supabase Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service key has full access — keep secret, only use server-side
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Stripe (Payments) ────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard → Products)
STRIPE_PRICE_FREE=price_free
STRIPE_PRICE_PRO=price_pro_monthly
STRIPE_PRICE_ENTERPRISE=price_enterprise_monthly

# ── n8n (Workflow Automation) ────────────────────────────────────────
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=

# ── Plausible (Analytics) ───────────────────────────────────────────
PLAUSIBLE_URL=http://localhost:8000
PLAUSIBLE_SECRET_KEY=generate-a-random-key
PLAUSIBLE_DISABLE_REG=true
# PostgreSQL for Plausible (only needed if self-hosting)
# PLAUSIBLE_DB_URL=postgres://plausible:plausible@plausible-db:5432/plausible

# ── Cal.com (Booking — optional) ────────────────────────────────────
# CALCOM_DB_URL=postgres://calcom:calcom@calcom-db:5432/calcom
# CALCOM_SECRET=generate-a-random-key
# CALCOM_URL=http://localhost:3000
